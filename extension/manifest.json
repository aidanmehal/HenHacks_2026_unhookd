{
  "manifest_version": 3,
  "name": "unhookd",
  "version": "0.1.0",
  "description": "Real-time phishing and malicious-link detector. No data stored.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": "images/logo.png",
    "default_title": "unhookd — Security Scanner"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html",
    "default_icon": "images/logo.png",
    "default_title": "unhookd"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
  "32": "images/icon32.png",
  "48": "images/icon48.png",
  "128": "images/icon128.png"
}
}
